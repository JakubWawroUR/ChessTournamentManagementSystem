<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.Player.PlayerTournaments">
    <children>
        <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="96.0" minHeight="10.0" prefHeight="90.0" vgrow="NEVER" /> <RowConstraints maxHeight="595.0" minHeight="10.0" prefHeight="560.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-padding: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-weight: bold;" text="Dane aktualnego gracza:" />
                    <Label fx:id="playerInfoLabel" text="Imię: [Brak danych]" />
                    <Label fx:id="playerRankingLabel" text="Ranking: [Brak danych]" />
                </VBox>

                <TableView fx:id="tournamentTable" prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="0" GridPane.rowIndex="1"> <columns>
                    <TableColumn fx:id="nameColumn" prefWidth="215.0" text="Nazwa Turnieju" />
                    <TableColumn fx:id="slotsInfoColumn" minWidth="2.0" prefWidth="215.0" text="Miejsca" />
                    <TableColumn fx:id="startDateColumn" prefWidth="215.0" text="Data rozpoczęcia" />
                    <TableColumn fx:id="endDateColumn" prefWidth="215.0" text="Data zakończenia" />
                    <TableColumn fx:id="operationsColumn" prefWidth="156.0" text="Operacje" />
                </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </GridPane>
    </children>
</AnchorPane>
