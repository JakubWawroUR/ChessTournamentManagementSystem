<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.Player.PlayerTournamentInfo">

    <children>
        <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="NEVER" />
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>
            <children>
                <fx:include fx:id="playerTopBar" source="PlayerTopBar.fxml" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                <HBox spacing="10.0" GridPane.rowIndex="1">

                    <fx:include fx:id="playerNavigationPanel" source="PlayerNavigationPanel.fxml" />

                    <AnchorPane fx:id="contentPane" HBox.hgrow="ALWAYS">
                        <children>
                            <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                <columnConstraints>
                                    <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" valignment="CENTER" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                <children>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                        <children>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Nazwa turnieju:">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="tournamentNameLabel" text="[brak danych]">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Liczba uczestników:">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="tournamentSlotsLabel" text="[brak danych]">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Data rozpoczęcia:">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="tournamentStartDateLabel" text="[brak danych]">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Data zakończenia:">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="tournamentEndDateLabel" text="[brak danych]">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Twój status:">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="currentPlayerStatusLabel" text="[brak danych]">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </HBox>
                                        </children>
                                        <padding>
                                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                        </padding>
                                    </VBox>
                                    <Label text="Uczestnicy Turnieju:" GridPane.halignment="LEFT" GridPane.valignment="BOTTOM" GridPane.rowIndex="1">
                                        <font>
                                            <Font size="18.0" />
                                        </font>
                                        <GridPane.margin>
                                            <Insets left="25.0" top="10.0" />
                                        </GridPane.margin>
                                    </Label>
                                    <TableView fx:id="participantsTable" prefHeight="200.0" prefWidth="200.0" GridPane.rowIndex="2">
                                        <columns>
                                            <TableColumn fx:id="firstNameColumn" prefWidth="75.0" text="Imię" />
                                            <TableColumn fx:id="lastNameColumn" prefWidth="75.0" text="Nazwisko" />
                                            <TableColumn fx:id="rankingColumn" prefWidth="75.0" text="Ranking" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                        <GridPane.margin>
                                            <Insets left="25.0" right="25.0" />
                                        </GridPane.margin>
                                    </TableView>
                                </children>
                            </GridPane>
                        </children>
                    </AnchorPane>
                </HBox>
            </children>
        </GridPane>
    </children>
</AnchorPane>