<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefWidth="250.0" spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.Admin.NavigationPanelController">
    <padding>
        <Insets left="15.0" top="15.0" />
    </padding>
    <children>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nawigacja">
            <font>
                <Font size="24.0" />
            </font>
        </Text>
        <Text onMouseClicked="#switchScene" fx:id="usersText" strokeType="OUTSIDE" strokeWidth="0.0" text="- Użytkownicy">
            <font>
                <Font size="18.0" />
            </font>
        </Text>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="- Turnieje" fx:id="tournamentsText" onMouseClicked="#switchScene">
            <font>
                <Font size="18.0" />
            </font>
        </Text>
    </children>
</VBox>
